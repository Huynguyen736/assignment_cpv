<mxfile host="Electron" version="21.6.8" type="device"><diagram id="flowchart_id" name="Flowchart"><mxGraphModel dx="2000" dy="2000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3000" pageHeight="3000" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="hc" value="Class HaarCascade" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#008a00;fontColor=#ffffff;strokeColor=#005700;opacity=90;fontStyle=1;fontSize=15;" vertex="1" parent="1"><mxGeometry x="50" y="597.5" width="140" height="60" as="geometry" /></mxCell><mxCell id="hc_init" value="Đọc file xml và nạp dữ liệu tham số đầu vào" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0050ef;fontColor=#ffffff;strokeColor=#001DBC;opacity=90;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="310" y="170.0" width="170" height="60" as="geometry" /></mxCell><mxCell id="edge_hc_hc_init" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc" target="hc_init"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_init_parse" value="Đọc cây XML bằng ET.parse&#10;Lấy nút gốc cascade (root.find)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="570" y="170.0" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_hc_init_hc_init_parse" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_init" target="hc_init_parse"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_init_win" value="Lấy kích thước khung cửa sổ gốc từ XML&#10;Tính win_area = win_w * win_h" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="830" y="170.0" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_hc_init_parse_hc_init_win" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_init_parse" target="hc_init_win"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_init_stages" value="Đọc cấu trúc các Tầng lọc (Stages) và Bộ phân loại yếu (Weak Classifiers)&#10;cascade.find('stages')" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1090" y="170.0" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_hc_init_win_hc_init_stages" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_init_win" target="hc_init_stages"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_init_weaks" value="Nạp các tham số của stage vào list" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1350" y="170.0" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_hc_init_stages_hc_init_weaks" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_init_stages" target="hc_init_weaks"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_init_thresh" value="stageThreshold" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fa6800;fontColor=#ffffff;strokeColor=#C73500;opacity=90;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1610" y="50.0" width="110" height="60" as="geometry" /></mxCell><mxCell id="edge_hc_init_weaks_hc_init_thresh" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_init_weaks" target="hc_init_thresh"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_init_stg_val" value="stage_threshold" style="whiteSpace=wrap;html=1;aspect=fixed;fillColor=#a0522d;fontColor=#ffffff;strokeColor=#6D1F00;opacity=90;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1870" y="50" width="100" height="100" as="geometry" /></mxCell><mxCell id="edge_hc_init_thresh_hc_init_stg_val" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_init_thresh" target="hc_init_stg_val"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_init_weakClf" value="weakClassifiers" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fa6800;fontColor=#ffffff;strokeColor=#C73500;opacity=90;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1610" y="170.0" width="110" height="60" as="geometry" /></mxCell><mxCell id="edge_hc_init_weaks_hc_init_weakClf" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_init_weaks" target="hc_init_weakClf"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_init_internal" value="internalNodes" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fa6800;fontColor=#ffffff;strokeColor=#C73500;opacity=90;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1870" y="170.0" width="110" height="60" as="geometry" /></mxCell><mxCell id="edge_hc_init_weakClf_hc_init_internal" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_init_weakClf" target="hc_init_internal"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_init_leaf" value="feature_idx&#10;threshold&#10;left_val&#10;right_val" style="whiteSpace=wrap;html=1;aspect=fixed;fillColor=#a0522d;fontColor=#ffffff;strokeColor=#6D1F00;opacity=90;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="2130" y="170" width="100" height="100" as="geometry" /></mxCell><mxCell id="edge_hc_init_internal_hc_init_leaf" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_init_internal" target="hc_init_leaf"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_init_feats" value="Nạp các tham số của danh sách tọa độ&#10;(x,y,w,h) và weight của các hcn đặc trưng" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1610" y="290" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_hc_init_weaks_hc_init_feats" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_init_weaks" target="hc_init_feats"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_int" value="Tính toán Ảnh tích phân&#10;(compute_integral_images)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0050ef;fontColor=#ffffff;strokeColor=#001DBC;opacity=90;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="310" y="470.0" width="170" height="60" as="geometry" /></mxCell><mxCell id="edge_hc_hc_int" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc" target="hc_int"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_int_float" value="Ép kiểu ảnh sang float64 chống tràn số" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="570" y="470.0" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_hc_int_hc_int_float" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_int" target="hc_int_float"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_int_cumsum1" value="Cộng dồn kết quả theo chiều ngang từ trái qua phải&#10;integral = cumsum(axis=0).cumsum(axis=1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="830" y="410" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_hc_int_float_hc_int_cumsum1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_int_float" target="hc_int_cumsum1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_int_cumsum2" value="Cộng dồn bình phương giá trị của từng pixel&#10;sq_integral = (img**2).cumsum(axis=0).cumsum(axis=1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="830" y="530" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_hc_int_float_hc_int_cumsum2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_int_float" target="hc_int_cumsum2"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_sum" value="Tính tổng giá trị của tất cả các pixel&#10;nằm trong một vùng hình chữ nhật" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0050ef;fontColor=#ffffff;strokeColor=#001DBC;opacity=90;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="310" y="650.0" width="170" height="60" as="geometry" /></mxCell><mxCell id="edge_hc_hc_sum" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc" target="hc_sum"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_sum_calc" value="Cộng và trừ các đỉnh của hcn trên mảng cộng dồn&#10;sum = I[y1,x1] - I[y0,x1] - I[y1,x0] + I[y0,x0]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="570" y="650" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_hc_sum_hc_sum_calc" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_sum" target="hc_sum_calc"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_dms" value="Phát hiện khuôn mặt ở nhiều tỷ lệ khác nhau&#10;bằng cửa sổ trượt (Sliding Window)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0050ef;fontColor=#ffffff;strokeColor=#001DBC;opacity=90;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="310" y="1025.0" width="170" height="60" as="geometry" /></mxCell><mxCell id="edge_hc_hc_dms" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc" target="hc_dms"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_dms_init" value="Khởi tạo hệ số thu phóng scale = 1.0&#10;và danh sách chứa tọa độ mặt thô detections = []" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="570" y="1025.0" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_hc_dms_hc_dms_init" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_dms" target="hc_dms_init"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_dms_loop" value="Vòng lặp thu nhỏ ảnh vô tận (while True)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fa6800;fontColor=#ffffff;strokeColor=#C73500;opacity=90;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="830" y="1025.0" width="110" height="60" as="geometry" /></mxCell><mxCell id="edge_hc_dms_init_hc_dms_loop" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_dms_init" target="hc_dms_loop"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_dms_break" value="Tính kích thước ảnh mới (w/scale, h/scale)&#10;Nếu nhỏ hơn 24x24 -&gt; Dừng (BREAK)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1090" y="920.0" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_hc_dms_loop_hc_dms_break" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_dms_loop" target="hc_dms_break"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_dms_resize" value="Thực hiện thu nhỏ ảnh bằng cv2.resize" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1350" y="920.0" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_hc_dms_break_hc_dms_resize" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_dms_break" target="hc_dms_resize"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_dms_calcint" value="Tính lại ảnh tích phân (Integral Image)&#10;cho ảnh thu nhỏ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1610" y="920.0" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_hc_dms_resize_hc_dms_calcint" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_dms_resize" target="hc_dms_calcint"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_dms_slide" value="Trượt cửa sổ 24x24 pixel trên toàn bộ ảnh&#10;từ trái qua phải, từ trên xuống dưới (Bước=4)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fa6800;fontColor=#ffffff;strokeColor=#C73500;opacity=90;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1870" y="920.0" width="110" height="60" as="geometry" /></mxCell><mxCell id="edge_hc_dms_calcint_hc_dms_slide" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_dms_calcint" target="hc_dms_slide"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_dms_var" value="Chuẩn hóa độ sáng bằng cách tính: trung bình (mean),&#10;phương sai (variance) và độ lệch chuẩn (std_dev)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="2130" y="830.0" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_hc_dms_slide_hc_dms_var" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_dms_slide" target="hc_dms_var"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_dms_stgloop" value="Lặp qua toàn bộ các&#10;Giai đoạn lọc (Stages)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fa6800;fontColor=#ffffff;strokeColor=#C73500;opacity=90;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="2390" y="830.0" width="110" height="60" as="geometry" /></mxCell><mxCell id="edge_hc_dms_var_hc_dms_stgloop" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_dms_var" target="hc_dms_stgloop"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_dms_wkloop" value="Lặp qua từng Bộ phân loại yếu&#10;(Weak Classifiers) trong Stage" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fa6800;fontColor=#ffffff;strokeColor=#C73500;opacity=90;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="2650" y="770.0" width="110" height="60" as="geometry" /></mxCell><mxCell id="edge_hc_dms_stgloop_hc_dms_wkloop" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_dms_stgloop" target="hc_dms_wkloop"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_dms_featval" value="Tính điểm Đặc trưng (feat_val) của vùng hiện tại&#10;thông qua các hình chữ nhật (x,y,w,h,weight)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="2910" y="770.0" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_hc_dms_wkloop_hc_dms_featval" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_dms_wkloop" target="hc_dms_featval"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_dms_eval" value="So sánh: feat_val &lt; ngưỡng * độ lệch chuẩn?&#10;Đúng -&gt; Cộng left_val. Sai -&gt; Cộng right_val" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="3170" y="770" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_hc_dms_featval_hc_dms_eval" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_dms_featval" target="hc_dms_eval"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_dms_stgeval" value="Cộng tổng điểm (stage_sum).&#10;Nếu stage_sum &lt; stage_threshold -&gt; Trượt (BREAK)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="2650" y="890" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_hc_dms_stgloop_hc_dms_stgeval" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_dms_stgloop" target="hc_dms_stgeval"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_dms_pass" value="Nếu vùng ảnh vượt qua TẤT CẢ các Giai đoạn&#10;-&gt; Nhân tọa độ với scale và lưu vào danh sách" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="2130" y="1010" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_hc_dms_slide_hc_dms_pass" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_dms_slide" target="hc_dms_pass"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="hc_dms_scale" value="Kết thúc lượt quét của 1 kích thước&#10;Tăng tỷ lệ thu nhỏ: scale *= scale_factor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1090" y="1130" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_hc_dms_loop_hc_dms_scale" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="hc_dms_loop" target="hc_dms_scale"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="fd" value="Class FaceDetector" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#008a00;fontColor=#ffffff;strokeColor=#005700;opacity=90;fontStyle=1;fontSize=15;" vertex="1" parent="1"><mxGeometry x="50" y="1360.0" width="140" height="60" as="geometry" /></mxCell><mxCell id="fd_init" value="Khởi tạo bộ nhận diện khuôn mặt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0050ef;fontColor=#ffffff;strokeColor=#001DBC;opacity=90;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="310" y="1300.0" width="170" height="60" as="geometry" /></mxCell><mxCell id="edge_fd_fd_init" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="fd" target="fd_init"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="fd_init_hc" value="Truyền đường dẫn XML để&#10;tạo đối tượng HaarCascade" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="570" y="1300.0" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_fd_init_fd_init_hc" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="fd_init" target="fd_init_hc"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="fd_init_sz" value="Lưu kích thước khuôn mặt đầu ra&#10;(Ví dụ: 112x112)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="830" y="1300" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_fd_init_hc_fd_init_sz" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="fd_init_hc" target="fd_init_sz"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="fd_det" value="Xử lý luồng Camera,&#10;lọc nhiễu và cắt ảnh" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0050ef;fontColor=#ffffff;strokeColor=#001DBC;opacity=90;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="310" y="1420.0" width="170" height="60" as="geometry" /></mxCell><mxCell id="edge_fd_fd_det" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="fd" target="fd_det"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="fd_det_gray" value="Chuyển ảnh màu (BGR) sang Đơn sắc (Grayscale)&#10;để giảm thiểu sai số ánh sáng" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="570" y="1420.0" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_fd_det_fd_det_gray" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="fd_det" target="fd_det_gray"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="fd_det_raw" value="Đẩy ảnh xám vào bộ phát hiện HaarCascade&#10;để nhận về danh sách tọa độ chồng chéo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="830" y="1420.0" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_fd_det_gray_fd_det_raw" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="fd_det_gray" target="fd_det_raw"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="fd_det_filt" value="Tính Width và Height của từng hộp tọa độ.&#10;Loại bỏ các khuôn mặt quá nhỏ (&lt; 60x60)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1090" y="1420.0" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_fd_det_raw_fd_det_filt" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="fd_det_raw" target="fd_det_filt"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="fd_det_nms" value="Tiến hành Gom cụm NMS (cv2.groupRectangles)&#10;để gộp các hộp đè lên nhau" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1350" y="1420.0" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_fd_det_filt_fd_det_nms" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="fd_det_filt" target="fd_det_nms"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="fd_det_crop" value="Lặp qua danh sách các hộp&#10;tọa độ chuẩn cuối cùng" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fa6800;fontColor=#ffffff;strokeColor=#C73500;opacity=90;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1610" y="1420.0" width="110" height="60" as="geometry" /></mxCell><mxCell id="edge_fd_det_nms_fd_det_crop" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="fd_det_nms" target="fd_det_crop"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="fd_det_slice" value="Sử dụng Numpy Slicing để cắt mảng ảnh (crop)&#10;face = gray[y:y+h, x:x+w]&#10;Thu phóng ảnh về đúng kích cỡ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1870" y="1420.0" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_fd_det_crop_fd_det_slice" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="fd_det_crop" target="fd_det_slice"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="fd_det_ret" value="Trả về danh sách mảng&#10;ảnh khuôn mặt và tọa độ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a20025;fontColor=#ffffff;strokeColor=#6F0000;opacity=90;align=center;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="2130" y="1420" width="190" height="70" as="geometry" /></mxCell><mxCell id="edge_fd_det_slice_fd_det_ret" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#4D4D4D;" edge="1" parent="1" source="fd_det_slice" target="fd_det_ret"><mxGeometry relative="1" as="geometry" /></mxCell></root></mxGraphModel></diagram></mxfile>